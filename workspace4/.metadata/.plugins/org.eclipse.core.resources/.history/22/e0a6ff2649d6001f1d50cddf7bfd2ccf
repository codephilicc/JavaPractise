package learn;

public class FindEquilibrium {

	public static void main(String[] args) {

		int a[]	 = {1, 2, 0, 3};
		int n = a.length;
		int count=0;
		int p1[]= new int[n];
		int sum = 0;
		for(int i =0;i<n;i++) {
			if(i==0) {
				p1[i]=0;
			}
			if(i>0) {
				sum +=a[i];
				p1[i]=sum;
			}
		}
		
		int p2[] = new int[n];
		int sum2 = 0;
		for(int j=n-1;j>0;j--) {
			if(j==n-1) {
				p2[n-1]=0;
			}
			if(j!=(n-1)) {
				sum2+=a[j];
				p2[j]=sum2;
			}
		}
		
		for(int k=0;k<n;k++) {
			if(p1[k]==p2[k]) {
				count++;
			}
			else count=0;
		} 
		System.out.println(count);
		
	}

}
