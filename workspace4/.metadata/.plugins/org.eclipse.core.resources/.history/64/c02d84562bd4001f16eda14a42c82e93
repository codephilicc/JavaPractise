package test;

import java.util.Arrays;

public class RotateByK {

	public static void main(String[] args) {

		int arr[] = {3,-2,1,4,6,9,8};
		int n = arr.length;
		int k =3;
		
		for(int i =0;i<k;i++) {
			int temp = 0;
			temp = arr[i];
			arr[i]= arr[n-k+i];
			arr[k+i]=temp;
			
			
		}
		System.out.println(Arrays.toString(arr));
		
	}

}
