package learn;

public class SumOfSubarray {

	public static void main(String[] args) {

		int[] arr = {1, 2,7,5,8, 3};
		int n = arr.length;
		int sum=0;
		
		for(int i=0;i<n;i++) {
			int temp=0;
			for(int j=i;j<n;j++) {
				temp+=arr[j];
				sum+=temp;
			}
		}
		System.out.println(sum);
		
		
		int x = 2*n-2;
		int result=0;
		for(int i=0;i<n;i++) {
			if(i==0) {
				result+=(n*arr[i]);
			}
			else if(i==n-1) {
				result+=(n*arr[n-1]);
			}
			else {
				result+=x*arr[i];
			}
		}
		System.out.println("result"+result);
	}

}
