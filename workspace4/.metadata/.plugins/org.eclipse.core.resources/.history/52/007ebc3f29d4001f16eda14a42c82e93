package test;

import java.util.Arrays;

public class RotateByK {

	public static void main(String[] args) {

		int arr[] = {3,-2,1,4,6,9,8};
		int n = arr.length;
		int k =3;
		
		while(k>0) {
			
			for(int i =0;i<n/2;i++) {
				int temp=0;
				temp=arr[i];
				arr[i] = arr[n-i-1];
				arr[n-i-1]=temp;
			}
			k--;
		}
		System.out.println(Arrays.toString(arr));
		
	}

}
