package learn;

public class PrintSubarray {

	public static void main(String[] args) {

		int[] arr = {3,2,1,4};
		
		int n = arr.length;
		int m = (n*(n+1))/2;
		
		int[] pf = new int[m];
		pf[0]=arr[0];
		
		for(int i=1;i<n;i++) {
			pf[i]=pf[i-1]+arr[i];
		}
		int sum=0;
		for(int k=0;k<n;k++) {
			for(int j=k;j<k;j++) {
				if(k==0) {
					sum=pf[j];
				}else {
					sum=pf[j]-pf[k-1];
				}
				System.out.println(sum);
			}
			System.out.println(sum);
		}
		
	}

}
