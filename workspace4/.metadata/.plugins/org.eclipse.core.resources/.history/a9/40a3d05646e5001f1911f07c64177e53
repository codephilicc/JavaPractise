package learn;

public class CountAG {

	public static void main(String[] args) {

		String s = "abeagag";
		char[]  c = s.toCharArray();
		int n = s.length();
		int total = 0;
		int count_a = 0;
		
		
		for(int i=0;i<n;i++ ) {
			if(c[i]=='a') {
				count_a+=1;
			}
			if(c[i]=='g') {
				total+=count_a;
			}
		}
		 System.out.println(total);
	}

}
