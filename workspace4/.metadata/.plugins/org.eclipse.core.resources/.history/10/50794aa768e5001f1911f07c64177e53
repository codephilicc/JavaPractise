package learn;

public class EvenSubarrays {

	public static void main(String[] args) {
			int[] A= {2, 4, 8, 7, 6};
		  int n = A.length;
	        String s ="NO";
	        
	       if(n%2==0 && n!=0 && n==1){
	            if((A[n-1]%2==0)&& A[0]%2==0 && A[n/2]%2==0 && A[(n-1)/2]%2==0)
	                s="YES";
	         } System.out.println(s);
	}

}
