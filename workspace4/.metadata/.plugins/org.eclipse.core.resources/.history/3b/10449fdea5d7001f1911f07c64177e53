package learn;

import java.util.Arrays;

public class EvenNumRange {

	public static void main(String[] args) {
		
		int[] A = {1, 2, 3, 4, 5};
		int[][] B = {{0,2},{2,4},{1,4}};

		 int n = A.length;
	        int m = B.length;
	        int[] C = new int[m];
	        if(A[0]%2==0){
	            A[0]=1;
	        }else A[0]=0;

	        for(int i =1;i<n;i++){
	            if(A[i]%2==0){
	             A[i]=1; 
	            }else A[i]=0;

	            A[i]+=A[i-1];
	            
	        }
	        for(int i=0;i<m;i++){
	            
	            int k = B[i][1];
	            for(int j = B[i][0];j<=k;j++){
	                C[i]+=A[j];
	            }
	        } System.out.println(Arrays.toString(C));

		
		
	}

}
